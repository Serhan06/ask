#!/usr/bin/env bash

set -euo pipefail

# Check required dependencies
for cmd in curl jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "ask: required command not found: $cmd" >&2
        exit 1
    fi
done

missing_vars=()
[[ -z "${ASK_API_URL:-}" ]] && missing_vars+=("ASK_API_URL")
[[ -z "${ASK_MODEL:-}"   ]] && missing_vars+=("ASK_MODEL")
[[ -z "${ASK_API_KEY:-}" ]] && missing_vars+=("ASK_API_KEY")

if (( ${#missing_vars[@]} > 0 )); then
    echo "ask: missing required environment variable(s): ${missing_vars[*]}" >&2
    echo "Please set ASK_API_URL, ASK_MODEL, and ASK_API_KEY." >&2
    exit 1
fi

args_prompt=""
if (( $# > 0 )); then
    args_prompt="$*"
fi

stdin_prompt=""
if [[ ! -t 0 ]]; then
    stdin_prompt="$(cat)"
fi

if [[ -n "$args_prompt" && -n "$stdin_prompt" ]]; then
    user_prompt="${args_prompt}"$'\n'"${stdin_prompt}"
elif [[ -n "$args_prompt" ]]; then
    user_prompt="$args_prompt"
elif [[ -n "$stdin_prompt" ]]; then
    user_prompt="$stdin_prompt"
else
    echo "ask: no prompt provided" >&2
    echo "Usage: ask \"your prompt\"  |  echo data | ask \"context:\"" >&2
    exit 1
fi