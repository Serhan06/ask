#!/usr/bin/env bash

set -euo pipefail

# Check required dependencies
for cmd in curl jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "ask: required command not found: $cmd" >&2
        exit 1
    fi
done

missing_vars=()
[[ -z "${ASK_API_URL:-}" ]] && missing_vars+=("ASK_API_URL")
[[ -z "${ASK_MODEL:-}"   ]] && missing_vars+=("ASK_MODEL")
[[ -z "${ASK_API_KEY:-}" ]] && missing_vars+=("ASK_API_KEY")

if (( ${#missing_vars[@]} > 0 )); then
    echo "ask: missing required environment variable(s): ${missing_vars[*]}" >&2
    echo "Please set ASK_API_URL, ASK_MODEL, and ASK_API_KEY." >&2
    exit 1
fi

args_prompt=""
if (( $# > 0 )); then
    args_prompt="$*"
fi

stdin_prompt=""
if [[ ! -t 0 ]]; then
    stdin_prompt="$(cat)"
fi

if [[ -n "$args_prompt" && -n "$stdin_prompt" ]]; then
    user_prompt="${args_prompt}"$'\n'"${stdin_prompt}"
elif [[ -n "$args_prompt" ]]; then
    user_prompt="$args_prompt"
elif [[ -n "$stdin_prompt" ]]; then
    user_prompt="$stdin_prompt"
else
    echo "ask: no prompt provided" >&2
    echo "Usage: ask \"your prompt\"  |  echo data | ask \"context:\"" >&2
    exit 1
fi

system_prompt="You are a CLI tool. Output plain text only. No yapping. Keep the output concise."

request_body="$(jq -n \
    --arg model   "$ASK_MODEL" \
    --arg system  "$system_prompt" \
    --arg user    "$user_prompt" \
    '{
        model: $model,
        messages: [
            { role: "system", content: $system },
            { role: "user",   content: $user   }
        ]
    }')"
tmp_body="$(mktemp)"
trap 'rm -f "$tmp_body"' EXIT

http_status="$(curl -sS \
    -o "$tmp_body" \
    -w '%{http_code}' \
    -X POST "$ASK_API_URL" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $ASK_API_KEY" \
    --data-binary "$request_body")" || {
        echo "ask: HTTP request failed" >&2
        exit 1
    }

response_body="$(cat "$tmp_body")"

if [[ "$http_status" -lt 200 || "$http_status" -ge 300 ]]; then
    err_msg="$(printf '%s' "$response_body" | jq -r '.error.message // .error // empty' 2>/dev/null || true)"
    if [[ -n "$err_msg" ]]; then
        echo "ask: API error (HTTP $http_status): $err_msg" >&2
    else
        echo "ask: API error (HTTP $http_status): $response_body" >&2
    fi
    exit 1
fi
content="$(printf '%s' "$response_body" | jq -er '.choices[0].message.content' 2>/dev/null)" || {
    echo "ask: failed to parse API response" >&2
    echo "Raw response: $response_body" >&2
    exit 1
}

printf '%s\n' "$content"